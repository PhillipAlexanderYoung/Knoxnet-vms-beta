# Knoxnet VMS Beta public configuration
KNX_APP_NAME="Knoxnet VMS Beta"

# Public beta update check. The app only notifies when a newer beta exists.
KNOXNET_CLOUD_API_BASE=https://api.knoxnetvms.com
KNOXNET_UPDATE_CHANNEL=beta
# KNOXNET_UPDATE_MANIFEST_URL=https://api.knoxnetvms.com/v1/updates/latest?channel={channel}&os={os}

# Desktop startup. Set to 0 if you prefer to start backend/MediaMTX manually.
KNOXNET_AUTOSTART_SERVICES=1

# MediaMTX local defaults.
MEDIAMTX_API_URL=http://127.0.0.1:9997/v3
MEDIAMTX_WEBRTC_URL=http://127.0.0.1:8889
MEDIAMTX_HLS_URL=http://127.0.0.1:8888
MEDIAMTX_RTSP_URL=rtsp://127.0.0.1:8554
MEDIAMTX_API_USERNAME=
MEDIAMTX_API_PASSWORD=

# Optional email notifications. Fill these in only if you want email alerts.
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_DEFAULT_TO=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_MOTION_AUTOSEND=false
EMAIL_MOTION_COOLDOWN_SEC=90

# Optional external AI providers. Leave blank for local/demo workflows.
AI_PROVIDER=
OPENAI_API_KEY=
GROK_API_KEY=
AI_BASE_URL=
